{
  "name": "soyoucloud",
  "version": "1.1.1",
  "description": "Client SoundCloud légitime et privé avec blocage des publicités.",
  "main": "main.js",
  "scripts": {
    "start": "electron --no-sandbox .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win && electron-builder --linux"
  },
  "keywords": [
    "soundcloud",
    "electron",
    "adblock",
    "privacy",
    "linux"
  ],
  "author": {
    "name": "Soyoudv",
    "email": "noname54765@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.0"
  },
  "build": {
    "appId": "com.soyou.soyoucloud",
    "productName": "SoyouCloud",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "cust_modules/**/*",
      "utils/**/*",
      "styles/**/*",
      "assets/**/*",
      "soundcloud-blocklist.txt",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/sc_icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/sc_icon.png"
    }
  }
}
